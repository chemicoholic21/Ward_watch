# GhostOffice (Next.js) Environment Configuration
# Copy to .env.local before running `npm run dev`.

# ──────────────────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# Same-origin in production. Set only if you deploy the API on a separate host.
NEXT_PUBLIC_API_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Agents (LLM provider — free tier via Groq, hosting Meta's open-weight Llama)
# ──────────────────────────────────────────────────────────────────────────────
# Get a free key (no card required, 30 RPM / 14.4k RPD free tier):
#   https://console.groq.com/keys
GROQ_API_KEY=
# Override the model if you want — defaults to llama-3.3-70b-versatile.
# Other free options on Groq: llama-3.1-8b-instant (faster, smaller),
# llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it.
# AGENT_MODEL_ID=llama-3.3-70b-versatile

# ──────────────────────────────────────────────────────────────────────────────
# MongoDB (the only data store now — Elasticsearch is gone)
# ──────────────────────────────────────────────────────────────────────────────
# Local docker-compose:
MONGO_URI=mongodb://localhost:27017
# Or hosted MongoDB Atlas:
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=ghostoffice

# ──────────────────────────────────────────────────────────────────────────────
# AWS (optional — gated by feature flags below)
# ──────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v1

S3_BUCKET_NAME=ghostoffice-civic-data
S3_REGION=us-east-1

SNS_CIVIC_ALERTS_TOPIC=
SNS_SECURITY_ALERTS_TOPIC=

LAMBDA_SCAM_SCANNER_ARN=
LAMBDA_ANOMALY_DETECTOR_ARN=

# ──────────────────────────────────────────────────────────────────────────────
# Feature flags — turn AWS integrations off when you don't have credits
# ──────────────────────────────────────────────────────────────────────────────
ENABLE_BEDROCK=false
ENABLE_LAMBDA=false
ENABLE_SNS=false

# ──────────────────────────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────────────────────────
API_KEY_SECRET=dev-api-key-secret
JWT_SECRET=dev-jwt-secret
# CORS only matters if the API is hit from a different origin. With the unified
# Next.js app the UI and API share an origin so this can usually stay empty.
CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Rate limiting (applied by middleware.ts to /api/*)
# ──────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
