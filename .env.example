# GhostOffice Environment Configuration

# Elasticsearch Cloud
ES_CLOUD_ID=ghostoffice:your-cloud-id-here
ES_API_KEY=your-api-key-here
ES_NODE=https://your-cluster.es.region.aws.found.io:443

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# AWS Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v1

# AWS S3
S3_BUCKET_NAME=ghostoffice-civic-data
S3_REGION=us-east-1

# AWS SNS
SNS_CIVIC_ALERTS_TOPIC=arn:aws:sns:us-east-1:123456789:civic-alerts
SNS_SECURITY_ALERTS_TOPIC=arn:aws:sns:us-east-1:123456789:security-alerts

# AWS Lambda Endpoints
LAMBDA_SCAM_SCANNER_ARN=arn:aws:lambda:us-east-1:123456789:function:scam-scanner
LAMBDA_ANOMALY_DETECTOR_ARN=arn:aws:lambda:us-east-1:123456789:function:anomaly-detector

# Backend API
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Security
API_KEY_SECRET=your-api-key-secret
JWT_SECRET=your-jwt-secret
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
